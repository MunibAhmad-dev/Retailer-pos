{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "dist-electron",
    "rootDir": "src/main",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "moduleResolution": "node",
    "types": ["node"]
  },
  "include": [
    "src/main/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src/renderer",
    "src/**/*.test.ts",
    "dist",
    "dist-electron"
  ]
}