{
  "extends": "@react-native/typescript-config/react-native.json",
  "compilerOptions": {
    "jsx": "react-native",
    "lib": ["ES2020"],
    "target": "ES2020",
    "moduleResolution": "node",
    "allowJs": true,
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*":            ["src/*"],
      "@components/*":  ["src/components/*"],
      "@screens/*":     ["src/screens/*"],
      "@theme/*":       ["src/theme/*"],
      "@api/*":         ["src/api/*"],
      "@store/*":       ["src/store/*"],
      "@hooks/*":       ["src/hooks/*"],
      "@utils/*":       ["src/utils/*"],
      "@i18n/*":        ["src/i18n/*"],
      "@navigation/*":  ["src/navigation/*"]
    }
  },
  "include": ["src", "App.tsx", "index.js"],
  "exclude": ["node_modules", "babel.config.js", "metro.config.js", "__tests__"]
}
